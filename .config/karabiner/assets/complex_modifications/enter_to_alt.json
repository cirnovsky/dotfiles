{
  "title": "Dual-role Enter",
  "rules": [
    {
      "description": "Tap Enter for Return, Hold for Left Alt (Option)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "return_or_enter",
            "modifiers": { "optional": ["any"] }
          },
          "to": [
            { "key_code": "left_option" }
          ],
          "to_if_alone": [
            { "key_code": "return_or_enter" }
          ]
        }
      ]
    }
  ]
}
